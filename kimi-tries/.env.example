# Chave de API
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelos por tarefa (opcional, tem defaults)
PIPELINE_MODEL_P0=kimi-k2-5        # Extração
PIPELINE_MODEL_P1=kimi-k2-6        # Análise
PIPELINE_MODEL_P2=kimi-k2-6        # Conjecturas
PIPELINE_MODEL_P3=kimi-k2-6        # Verificação
PIPELINE_MODEL_REPAIR=kimi-k2-5    # Repair primário
PIPELINE_MODEL_REPAIR_LAST=kimi-k2-6  # Repair escalado
PIPELINE_MODEL_P6=kimi-k2-6        # Prova

# Limiar de escalonamento (tentativas com K2.5 antes de escalar)
REPAIR_ESCALATION_THRESHOLD=2

sSANDBOX_PYTHON=.venv-sandbox/bin/python
